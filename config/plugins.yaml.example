# Plugin registry
# Copy this file to plugins.yaml and edit to match your environment.
# Each entry: name, module, priority, config, enabled (all required)

- name: trello
  module: seosoyoung_plugins.trello.plugin
  priority: 100
  config: config/trello.yaml
  enabled: true

- name: translate
  module: seosoyoung_plugins.translate.plugin
  priority: 50
  config: config/translate.yaml
  enabled: true
