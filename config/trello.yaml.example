# Trello plugin configuration
# Copy this file to trello.yaml and fill in your actual values.
# All values are required. Do not leave placeholders.

api_key: YOUR_TRELLO_API_KEY
token: YOUR_TRELLO_TOKEN
board_id: YOUR_BOARD_ID
notify_channel: YOUR_SLACK_CHANNEL_ID
dm_target_user_id: YOUR_SLACK_USER_ID
poll_interval: 15
polling_debug: false

execute_emoji: rocket

watch_lists:
  to_go: YOUR_TO_GO_LIST_ID

list_ids:
  draft: ""
  backlog: YOUR_BACKLOG_LIST_ID
  in_progress: YOUR_IN_PROGRESS_LIST_ID
  blocked: ""
  review: YOUR_REVIEW_LIST_ID
  done: YOUR_DONE_LIST_ID
